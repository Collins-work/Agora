# ── Agora Backend Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values

# KoraPay API Keys (get from https://dashboard.korapay.com)
KORAPAY_SECRET_KEY=sk_test_your_korapay_secret_key_here
KORAPAY_PUBLIC_KEY=pk_test_your_korapay_public_key_here
DATABASE_URL=postgres://username:password@hostname:5432/database_name

# Server config
PORT=4000

# Webhook URL (use ngrok in development: ngrok http 4000)
WEBHOOK_URL=https://your-ngrok-url.ngrok.io

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# ── Demo OTP providers ─────────────────────────────────────────────────────
# Email demo option: use Ethereal (https://ethereal.email/create) or Mailtrap
# SMTP_HOST=smtp.ethereal.email
# SMTP_PORT=587
# SMTP_USER=your-ethereal-user
# SMTP_PASS=your-ethereal-pass
# SMTP_SECURE=false
# SMTP_FROM="Agora <no-reply@agora.local>"

# SMS demo option: Twilio test credentials or a real Twilio number
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_FROM=+12125551234

# Mock OTP delivery instead of sending real emails/SMS
# Set MOCK_OTP=true for demo mode
# MOCK_OTP=true

# If you want the backend to behave fully offline for demo purposes,
# leave SMTP/Twilio commented out. The app will log OTP codes in the server console.
